{
  "manifest_version": 3,
  "name": "Renma — Smart Image Renamer",
  "version": "1.1.0",
  "description": "Auto-renames downloaded images with domain-aware prefixes, custom templates, and folder routing.",
  "permissions": ["downloads", "storage", "tabs"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_icon": { "16": "icon.png", "32": "icon.png", "48": "icon.png", "128": "icon.png" } },
  "options_page": "options.html",
  "icons": { "16": "icon.png", "32": "icon.png", "48": "icon.png", "128": "icon.png" }
}
